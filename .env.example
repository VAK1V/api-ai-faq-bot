# Database
POSTGRES_USER=faq_user
POSTGRES_PASSWORD=faq_password
POSTGRES_DB=faq_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Hugging Face Model (GGUF)
MODEL_REPO=t-tech/T-lite-it-2.1-GGUF
MODEL_FILE=T-lite-it-2.1-Q4_K_M.gguf
MAX_TEXT_LENGTH=500
MAX_TOKENS=256
N_THREADS=4
N_CTX=4096
TEMPERATURE=0.7

# Optional: API Key for authorization
# API_KEY=your-secret-api-key
